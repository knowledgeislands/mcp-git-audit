{
  "name": "@knowledgeislands/mcp-git-audit",
  "description": "MCP for branch, working-tree, and upstream status across local git repositories.",
  "version": "1.0.0",
  "author": "kris@kris.me.uk",
  "bin": {
    "mcp-git-audit": "dist/mcp-server/index.js"
  },
  "bugs": {
    "url": "https://github.com/knowledgeislands/mcp-git-audit/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "markdownlint-cli2": "^0.23.1",
    "mcporter": "^0.12.3",
    "prettier": "^3.9.5",
    "syncpack": "^15.3.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/mcp-server/index.d.ts",
      "import": "./dist/mcp-server/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./repo-audit": {
      "types": "./dist/main/repo-audit/index.d.ts",
      "import": "./dist/main/repo-audit/index.js"
    },
    "./repo-commit": {
      "types": "./dist/main/repo-commit/index.d.ts",
      "import": "./dist/main/repo-commit/index.js"
    },
    "./repo-remotes": {
      "types": "./dist/main/repo-remotes/index.d.ts",
      "import": "./dist/main/repo-remotes/index.js"
    },
    "./repo-sync": {
      "types": "./dist/main/repo-sync/index.d.ts",
      "import": "./dist/main/repo-sync/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/knowledgeislands/mcp-git-audit#readme",
  "keywords": [
    "anthropic",
    "audit",
    "claude",
    "git",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js,json,jsonc}": "bunx @biomejs/biome check --write --no-errors-on-unmatched",
    "*.md": [
      "bunx prettier --write",
      "bunx markdownlint-cli2"
    ]
  },
  "main": "dist/mcp-server/index.js",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/knowledgeislands/mcp-git-audit.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf {dist,node_modules}",
    "ki:audit": "bun .ki-meta/bin/aggregate.ts audit",
    "ki:authoring:audit": "bun .ki-meta/checkers/ki-authoring/scripts/audit.ts .",
    "ki:authoring:conform": "bun .ki-meta/checkers/ki-authoring/scripts/conform.ts .",
    "ki:conform": "bun .ki-meta/bin/aggregate.ts conform",
    "ki:educate": "bun .ki-meta/bin/aggregate.ts educate",
    "ki:engineering:audit": "bun .ki-meta/checkers/ki-engineering/scripts/audit.ts .",
    "ki:engineering:conform": "bun .ki-meta/checkers/ki-engineering/scripts/conform.ts .",
    "ki:generate:client": "mcporter emit-ts kit-mcp-git-audit --mode client --out src/generated/client.ts --types-out src/generated/types.d.ts && printf '// @ts-nocheck\\n' | cat - src/generated/client.ts > /tmp/gen-tmp.ts && mv /tmp/gen-tmp.ts src/generated/client.ts",
    "ki:help": "bun .ki-meta/bin/aggregate.ts help",
    "ki:mcp:audit": "bun .ki-meta/checkers/ki-mcp/scripts/audit.ts .",
    "ki:mcp:conform": "bun .ki-meta/checkers/ki-mcp/scripts/conform.ts .",
    "ki:project-roadmap:audit": "bun .ki-meta/checkers/ki-repo-roadmap/scripts/audit.ts .",
    "ki:project-roadmap:conform": "bun .ki-meta/checkers/ki-repo-roadmap/scripts/conform.ts .",
    "ki:repo:audit": "bun .ki-meta/checkers/ki-repo/scripts/audit.ts .",
    "ki:repo:conform": "bun .ki-meta/checkers/ki-repo/scripts/conform.ts .",
    "ki:server:mcp:dev": "NODE_ENV=development bun --watch src/mcp-server/index.ts",
    "ki:server:mcp:inspect": "NODE_ENV=development bunx @modelcontextprotocol/inspector bun src/mcp-server/index.ts",
    "ki:server:mcp:start": "bun run build && node dist/mcp-server/index.js",
    "ki:test:smoke": "bun run build && bun scripts/smoke.ts",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "type": "module"
}
